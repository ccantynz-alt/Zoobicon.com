# ============================================================
# Zoobicon Environment Configuration
# Copy this file to .env.local and fill in your values:
#   cp .env.local.example .env.local
# ============================================================

# ── REQUIRED ──────────────────────────────────────────────────
# Without these, the builder cannot generate websites.

# Anthropic API key (Claude) — powers the core AI pipeline
# Get yours at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Neon serverless Postgres — stores users, projects, sites, deployments
# Get yours at: https://console.neon.tech/ (free tier available)
DATABASE_URL=

# ── AI PROVIDERS (Optional) ──────────────────────────────────
# Additional AI models users can select in the builder.
# The builder works with just ANTHROPIC_API_KEY, but these unlock more models.

# OpenAI — enables GPT-4o, GPT-4o-mini, o3, DALL-E images
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google AI — enables Gemini 2.5 Pro, Gemini 2.5 Flash
# Get yours at: https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=

# ── PAYMENTS ──────────────────────────────────────────────────
# Stripe integration for paid tiers. Without these, payments won't work
# but the builder still functions on the free tier.

# Stripe secret key — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=

# Stripe price IDs — create products in Stripe Dashboard for each plan:
#   Creator ($19/mo), Pro ($49/mo), Agency ($99/mo)
# Enterprise is contact-sales only (no self-serve checkout)
STRIPE_CREATOR_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_AGENCY_PRICE_ID=

# Stripe webhook secret — from https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=

# ── IDEMPOTENCY STORE (Upstash Redis) ────────────────────────
# Used for cross-instance dedup of Stripe webhook events so cold starts can't
# cause duplicate charges. SET NX with 24h expiry — same retry window Stripe
# uses. Without these, the handler falls back to a single-instance in-memory
# cache that EMPTIES on every Vercel cold start. With live customers this
# creates duplicate subscriptions on retry. SET THESE.
# Get a free account at https://upstash.com (10K commands/day free tier —
# plenty for webhook dedup) → create a Global Redis database → copy the REST
# URL + token from the "REST API" tab.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── AUTH & ADMIN ──────────────────────────────────────────────

# Admin credentials (fallback when database is unavailable)
ADMIN_EMAIL=admin@zoobicon.com
ADMIN_PASSWORD=changeme-in-production

# Secret for signing password reset tokens (random string)
RESET_TOKEN_SECRET=

# ── OAUTH (Optional) ─────────────────────────────────────────
# Enable Google and GitHub sign-in on the auth pages.

# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth — https://github.com/settings/developers
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# ── EMAIL DELIVERY (Mailgun) ─────────────────────────────────
# All email delivery — admin notifications, support tickets, password resets.
# Without MAILGUN_API_KEY, emails log to console instead.

# Mailgun API key — https://app.mailgun.com/settings/api_security
MAILGUN_API_KEY=

# Mailgun domain — the verified sending domain
MAILGUN_DOMAIN=zoobicon.com

# Mailgun webhook signing key — for verifying inbound webhook payloads
MAILGUN_WEBHOOK_SIGNING_KEY=

# Where to receive admin notifications (contact forms, signups, deploys).
# Falls back to ADMIN_EMAIL if not set.
ADMIN_NOTIFICATION_EMAIL=

# ── IMAGES (Optional) ────────────────────────────────────────
# AI image generation and stock photo search. Without these,
# generated sites use placeholder images.

# Unsplash — free stock photos in generated sites
# https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=

# Stability AI — AI-generated images for paid users
# https://platform.stability.ai/account/keys
STABILITY_API_KEY=

# ── ANALYTICS & SEO ──────────────────────────────────────────

# Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX)
# Get yours at: https://analytics.google.com/ → Admin → Data Streams
NEXT_PUBLIC_GA_ID=

# Google Search Console verification token
# Get yours at: https://search.google.com/search-console → Add Property → HTML tag method
NEXT_PUBLIC_GSC_VERIFICATION=

# ── INFRASTRUCTURE ────────────────────────────────────────────

# Public URL of the app (used in emails, Stripe callbacks, etc.)
NEXT_PUBLIC_APP_URL=https://zoobicon.com

# Cloudflare — DNS, SSL, and CDN management for hosted sites
# https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_ACCOUNT_ID=

# ── INTEGRATIONS (Optional) ──────────────────────────────────

# GitHub token — for the GitHub import feature
GITHUB_TOKEN=

# Slack integration
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=

# ── DOMAIN REGISTRATION (Tucows/OpenSRS) ─────────────────────
# Powers the /domains page. Without these, domain search returns
# simulated results and registrations are logged to console.

# OpenSRS reseller API key — from your Tucows reseller dashboard
OPENSRS_API_KEY=

# OpenSRS reseller username
OPENSRS_RESELLER_USER=

# "test" for sandbox (horizon.opensrs.net), "live" for production
OPENSRS_ENV=test

# ── VIDEO CREATOR (Replicate) ────────────────────────────────
# Powers the AI Video Creator. Without REPLICATE_API_TOKEN,
# video generation returns "service unavailable" errors.

# Replicate API token — https://replicate.com/account/api-tokens
# This is REQUIRED for video generation (voice, avatars, lip-sync)
REPLICATE_API_TOKEN=

# ── VIDEO CREATOR (Optional Providers) ───────────────────────
# Alternative/additional video providers. Not required if using Replicate.

# HeyGen — avatar video generation (legacy, not primary path)
# HEYGEN_API_KEY=

# ── ADDITIONAL PRODUCTS ──────────────────────────────────────

# Celitech — eSIM product (requires training before API access)
# CELITECH_API_KEY=

# Deepgram — AI Dictation product
# DEEPGRAM_API_KEY=

# Backblaze B2 — Cloud Storage product
# B2_KEY_ID=
# B2_APP_KEY=

# Cal.com — Booking & Scheduling product
# CALCOM_API_URL=
# CALCOM_API_KEY=

# Supabase — auto-provisioned databases for generated full-stack apps
# SUPABASE_ACCESS_TOKEN=
# SUPABASE_ORG_ID=
