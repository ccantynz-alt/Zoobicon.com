# Zoobicon Environment Variables
# ⚠️ NEVER commit the .env.local file — only this template
# Copy this file to .env.local and fill in real values

# ─── Anthropic AI ───────────────────────────────────────────
# Get your API key from https://console.anthropic.com/
ANTHROPIC_API_KEY=your_api_key_here

# ─── Admin Login ────────────────────────────────────────────
# The email address used to log in as admin (unlimited access)
ADMIN_EMAIL=admin@zoobicon.com
# A strong password for the admin account — keep this secret!
ADMIN_PASSWORD=change-me-to-something-strong

# ─── Email (Password Reset) ─────────────────────────────────
# Required to send forgot-password emails to customers.
# Recommended: https://resend.com  (free tier: 3,000 emails/mo)
# Once you have a key, wire it up in /src/app/api/auth/forgot-password/route.ts
RESEND_API_KEY=re_your_key_here

# Public base URL — used to build reset-link URLs in emails
NEXT_PUBLIC_APP_URL=https://zoobicon.com
