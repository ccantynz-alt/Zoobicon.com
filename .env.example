# Zoobicon Environment Variables
# ⚠️ NEVER commit the .env.local file — only this template
# Copy this file to .env.local and fill in real values

# ─── Anthropic AI ───────────────────────────────────────────
# Get your API key from https://console.anthropic.com/
ANTHROPIC_API_KEY=your_api_key_here

# ─── Admin Login ────────────────────────────────────────────
# The email address used to log in as admin (unlimited access)
ADMIN_EMAIL=admin@zoobicon.com
# A strong password for the admin account — keep this secret!
ADMIN_PASSWORD=change-me-to-something-strong
