# === Required ===
ANTHROPIC_API_KEY=your-anthropic-api-key

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Admin account (env-based, not in database)
ADMIN_EMAIL=admin@zoobicon.com
ADMIN_PASSWORD=your-admin-password

# === Stripe (payments) ===
STRIPE_SECRET_KEY=sk_live_...
STRIPE_CREATOR_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_AGENCY_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# === Idempotency store (Upstash Redis) ===
# Cross-instance dedup for Stripe webhook events so Vercel cold starts can't
# replay an event and double-charge a customer. Free tier at https://upstash.com
# covers webhook dedup easily (10K commands/day).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# === Multi-LLM (optional — unlocks model picker in builder) ===

# OpenAI — get key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
# Google AI — get key at https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=AIza...

# === OAuth (optional — enables Google/GitHub sign-in) ===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# === Email (Mailgun) — powers all emails ===
MAILGUN_API_KEY=key-...
MAILGUN_DOMAIN=zoobicon.com
MAILGUN_WEBHOOK_SIGNING_KEY=

# Admin notification email — receives contact forms, signups, deploys
# Falls back to ADMIN_EMAIL if not set
ADMIN_NOTIFICATION_EMAIL=you@yourdomain.com

# === Security ===
# Token signing (falls back to ADMIN_PASSWORD if not set)
RESET_TOKEN_SECRET=your-random-secret

# === Analytics & SEO ===
# Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=
# Google Search Console verification token
NEXT_PUBLIC_GSC_VERIFICATION=

# === Infrastructure ===
# App URL for email links and Stripe redirects
NEXT_PUBLIC_APP_URL=https://zoobicon.com

# Cloudflare (DNS/SSL/CDN management)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_ACCOUNT_ID=

# === Integrations (optional) ===
# Slack Bot Integration
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret

# GitHub token for import feature
GITHUB_TOKEN=

# === Images (optional) ===
# Unsplash — free stock photos
UNSPLASH_ACCESS_KEY=
# Stability AI — SDXL images
STABILITY_API_KEY=

# === Domain Registration (optional) ===
# The registrar chain attempts providers in order: OpenSRS → CentralNic.
# Set credentials for one or both. Unset providers are skipped. With both
# configured, OpenSRS handles the happy path and CentralNic catches outages,
# rate limits, and TLDs OpenSRS refuses.

# Tucows / OpenSRS — primary registrar (existing integration)
OPENSRS_API_KEY=
OPENSRS_RESELLER_USER=
# Set to "live" to register real domains. Anything else uses the test
# horizon endpoint, which never produces a real registration.
OPENSRS_ENV=test

# CentralNic Reseller (RRPproxy / Hexonet) — wholesale failover
# Sign up at https://www.centralnicreseller.com → API → Keys.
# Prefer the API key (revokable) over login+password.
CENTRALNIC_API_KEY=
# OR (only if no CENTRALNIC_API_KEY)
CENTRALNIC_LOGIN=
CENTRALNIC_PASSWORD=
# Set to "live" once you've verified an order on the OT&E test endpoint.
CENTRALNIC_ENV=ote

# Domain drops & aftermarket (optional — for the /domains/drops feed)
DROPCATCH_API_KEY=
SNAPNAMES_API_KEY=

# === Auth & secrets ===
# JWT signing secret. Required by /api/v1/data/[collection] to verify
# Bearer tokens issued to generated customer sites.
JWT_SECRET=
# Cron auth — every /api/cron/* endpoint requires `Authorization: Bearer <CRON_SECRET>`.
# REQUIRED in production: warm-replicate refuses to run without this so anyone
# hitting the URL can't spin paid Replicate workloads.
CRON_SECRET=
# Server-only admin API key for tools that don't go through cookie auth.
# Surfaced as `x-admin-key` header in the affiliate payouts API.
ADMIN_API_KEY=
# Recovery token used by /admin-recover to bootstrap a new admin password
# when the regular login is locked out. Long random string.
ADMIN_RECOVERY_TOKEN=
# Token gating server-side admin chat features.
ADMIN_CHAT_TOKEN=
# Master encryption key for vaulted credentials (vault-* libraries).
VAULT_MASTER_KEY=
# Salt seeded into IP-based analytics buckets so we never hash on raw IPs.
ANALYTICS_SALT_BASE=

# === Stripe price IDs (optional — fall back to STRIPE_*_PRICE_ID above) ===
STRIPE_PRICE_STARTER=
STRIPE_PRICE_CREATOR=
STRIPE_PRICE_CREATOR_ANNUAL=
STRIPE_PRICE_PRO=
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_PRICE_AGENCY=
STRIPE_PRICE_AGENCY_ANNUAL=
STRIPE_PRICE_WHITELABEL=
STRIPE_PRICE_WHITELABEL_ANNUAL=

# === AI / Generation providers ===
# Replicate — video pipeline + image gen. Any of these env names are accepted.
REPLICATE_API_TOKEN=
REPLICATE_API_KEY=
REPLICATE_TOKEN=
REPLICATE_KEY=
# fal.ai — Veo / Sora / Kling alternatives. Either key name works.
FAL_KEY=
FAL_API_KEY=

# === Video pipeline — Hedra Character-3 (primary lip-sync) ===
# Sub-100ms TTFB, $0.05/min — 15× cheaper than HeyGen Avatar IV.
# #1 quality benchmark for spokesperson talking-head as of April 2026.
# Up to 10-min videos via REST endpoint at api.hedra.com/web-app/public/v1.
# Currently in PRIVATE BETA — request access at https://www.hedra.com/api.
# When set, src/lib/video-pipeline.ts → generateLipSync tries Hedra FIRST
# and falls through to the existing 5-model Replicate chain on failure.
HEDRA_API_KEY=

# === Video pipeline — Fish Audio S1 (primary TTS) ===
# #1 on TTS-Arena2 (April 2026), beats ElevenLabs on quality benchmarks.
# 50+ languages, 48 emotion tags, 5 tone tags, $15 / 1M chars
# (≈80% cheaper than ElevenLabs Turbo at $90 / 1M chars).
# Sign up: https://fish.audio/  → Developer → API Keys
# Voice marketplace (1000s of free reference voices): https://fish.audio/m/
# When set, src/lib/video-pipeline.ts → generateVoice tries Fish S1 FIRST
# and falls through to the 5-model Replicate TTS chain on failure.
FISH_AUDIO_API_KEY=
# Optional: Fish reference_id for the default voice. Pick one from the
# marketplace (e.g. a clone of your CEO) and pin it here so every generation
# uses a consistent voice without callers having to specify voiceId.
FISH_AUDIO_DEFAULT_VOICE_ID=
# Legacy aliases — read by src/lib/fish-audio.ts when the canonical name above
# is unset. Keep both for compatibility with older Vercel envs.
FISH_API_KEY=
FISHAUDIO_API_KEY=

# === Voice — additional providers (fallback / specialty) ===
ELEVENLABS_API_KEY=
CARTESIA_API_KEY=
# Premium TTS — Play.ht
PLAYHT_API_KEY=
PLAYHT_USER_ID=
# Video models routed via fal.ai or direct API
HEYGEN_API_KEY=
KLING_API_KEY=
LUMA_API_KEY=
PIKA_API_KEY=
RUNWAY_API_KEY=
# Speech-to-text fallback for /api/transcribe
DEEPGRAM_API_KEY=
# Self-hosted video API (api.zoobicon.ai) URL once it's online
ZOOBICON_VIDEO_API_URL=
# Embeddings provider for the intel crawler
VOYAGE_API_KEY=

# === Telephony, social, and integrations ===
# Twilio for SMS / WhatsApp notifications
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_PHONE_NUMBER=
# Web Push (VAPID keys for browser notifications)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hello@zoobicon.com
# Discord bot
DISCORD_PUBLIC_KEY=
# Bluesky / Mastodon / Threads / Instagram / TikTok / Facebook integration
BLUESKY_DID=
MASTODON_INSTANCE=
INSTAGRAM_USER_ID=
THREADS_USER_ID=
FACEBOOK_PAGE_ID=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
# Notion + Figma deep-links
NOTION_TOKEN=
FIGMA_TOKEN=
# IPInfo for geo enrichment
IPINFO_TOKEN=
# Pexels for stock imagery alternative to Unsplash
PEXELS_API_KEY=

# === eSIM providers ===
# ESIM_PROVIDER selects which provider serves the v1 eSIM endpoints.
ESIM_PROVIDER=celitech
CELITECH_API_KEY=
CELITECH_WEBHOOK_SECRET=
AIRALO_API_KEY=
AIRALO_WEBHOOK_SECRET=

# === Booking, storage, telecoms ===
CALCOM_API_KEY=
CALCOM_API_URL=https://api.cal.com/v2
WIREGUARD_API_KEY=
WIREGUARD_API_URL=
# Backblaze B2 for the cloud-storage product
B2_KEY_ID=
B2_APP_KEY=
B2_BUCKET=

# === Email infrastructure (extras) ===
# Sender override for /api/email outbound (defaults to noreply@zoobicon.com)
MAILGUN_FROM=
# Dedicated SMTP credentials for outbound email when SMTP is preferred over the API
MAILGUN_SMTP_LOGIN=
MAILGUN_SMTP_PASSWORD=
# IMAP credentials for the inbound email reader (admin/email page)
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
# Amazon SES — optional alternative to Mailgun for transactional email
AWS_SES_REGION=
AWS_SES_ACCESS_KEY_ID=
AWS_SES_SECRET_ACCESS_KEY=
AWS_SES_SMTP_USER=
AWS_SES_SMTP_PASSWORD=

# === Supabase auto-provisioning ===
# Powers the "every generated app gets a real backend from day one" flow.
SUPABASE_ACCESS_TOKEN=
SUPABASE_ORG_ID=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# === Vercel deploy hooks ===
# Vercel API token for programmatic deploys + the developer panel
VERCEL_TOKEN=
VERCEL_API_TOKEN=

# === Vercel Blob (assets, generated images) ===
BLOB_READ_WRITE_TOKEN=

# === GitHub OAuth (sister to GITHUB_OAUTH_* above for the import flow) ===
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# === QStash (durable cron via Upstash) ===
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# === Crontech (Craig's combined backend + frontend platform) ===
CRONTECH_API_KEY=
CRONTECH_API_URL=

# === Cloudflare extras ===
CLOUDFLARE_BROWSER_RENDERING_TOKEN=

# === SEO + indexing ===
GOOGLE_INDEXING_SERVICE_ACCOUNT=
INDEXNOW_KEY=

# === OpenSRS aliases ===
# Older code paths look for OPENSRS_USER / OPENSRS_USERNAME alongside OPENSRS_RESELLER_USER.
OPENSRS_USER=
OPENSRS_USERNAME=

# === Public site URLs ===
# Used by sitemap / canonical / share URLs when running outside zoobicon.com
NEXT_PUBLIC_SITE_URL=https://zoobicon.com
NEXT_PUBLIC_BASE_URL=https://zoobicon.com
# Custom origins allowed to call /api/v1/data (comma-separated full origins)
NEXT_PUBLIC_DATA_API_ALLOWED_ORIGINS=
# Real-time collab WebSocket endpoint
NEXT_PUBLIC_COLLAB_WS_URL=
# Toggle for the experimental WebContainers preview
NEXT_PUBLIC_WEBCONTAINERS_ENABLED=
# Short-link domain (defaults to https://zoo.bi)
SHORT_LINK_BASE_URL=

# === Gate Test (Craig's external in-browser QA service) ===
NEXT_PUBLIC_GATE_TEST_API_URL=
NEXT_PUBLIC_GATE_TEST_API_KEY=
