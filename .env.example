# === Required ===
ANTHROPIC_API_KEY=your-anthropic-api-key

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Admin account (env-based, not in database)
ADMIN_EMAIL=admin@zoobicon.com
ADMIN_PASSWORD=your-admin-password

# === Stripe (payments) ===
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# === Optional ===

# Email sending (Resend)
RESEND_API_KEY=re_...

# Token signing (falls back to ADMIN_PASSWORD if not set)
RESET_TOKEN_SECRET=your-random-secret

# App URL for email links and Stripe redirects
NEXT_PUBLIC_APP_URL=https://zoobicon.com
