# === Required ===
ANTHROPIC_API_KEY=your-anthropic-api-key

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Admin account (env-based, not in database)
ADMIN_EMAIL=admin@zoobicon.com
ADMIN_PASSWORD=your-admin-password

# === Stripe (payments) ===
STRIPE_SECRET_KEY=sk_live_...
STRIPE_CREATOR_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_AGENCY_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# === Idempotency store (Upstash Redis) ===
# Cross-instance dedup for Stripe webhook events so Vercel cold starts can't
# replay an event and double-charge a customer. Free tier at https://upstash.com
# covers webhook dedup easily (10K commands/day).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# === Multi-LLM (optional — unlocks model picker in builder) ===

# OpenAI — get key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
# Google AI — get key at https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=AIza...

# === OAuth (optional — enables Google/GitHub sign-in) ===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# === Email (Mailgun) — powers all emails ===
MAILGUN_API_KEY=key-...
MAILGUN_DOMAIN=zoobicon.com
MAILGUN_WEBHOOK_SIGNING_KEY=

# Admin notification email — receives contact forms, signups, deploys
# Falls back to ADMIN_EMAIL if not set
ADMIN_NOTIFICATION_EMAIL=you@yourdomain.com

# === Security ===
# Token signing (falls back to ADMIN_PASSWORD if not set)
RESET_TOKEN_SECRET=your-random-secret

# === Analytics & SEO ===
# Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=
# Google Search Console verification token
NEXT_PUBLIC_GSC_VERIFICATION=

# === Infrastructure ===
# App URL for email links and Stripe redirects
NEXT_PUBLIC_APP_URL=https://zoobicon.com

# Cloudflare (DNS/SSL/CDN management)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_ACCOUNT_ID=

# === Integrations (optional) ===
# Slack Bot Integration
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret

# GitHub token for import feature
GITHUB_TOKEN=

# === Images (optional) ===
# Unsplash — free stock photos
UNSPLASH_ACCESS_KEY=
# Stability AI — SDXL images
STABILITY_API_KEY=

# === Domain Registration (optional) ===
# The registrar chain attempts providers in order: OpenSRS → CentralNic.
# Set credentials for one or both. Unset providers are skipped. With both
# configured, OpenSRS handles the happy path and CentralNic catches outages,
# rate limits, and TLDs OpenSRS refuses.

# Tucows / OpenSRS — primary registrar (existing integration)
OPENSRS_API_KEY=
OPENSRS_RESELLER_USER=
# Set to "live" to register real domains. Anything else uses the test
# horizon endpoint, which never produces a real registration.
OPENSRS_ENV=test

# CentralNic Reseller (RRPproxy / Hexonet) — wholesale failover
# Sign up at https://www.centralnicreseller.com → API → Keys.
# Prefer the API key (revokable) over login+password.
CENTRALNIC_API_KEY=
# OR (only if no CENTRALNIC_API_KEY)
CENTRALNIC_LOGIN=
CENTRALNIC_PASSWORD=
# Set to "live" once you've verified an order on the OT&E test endpoint.
CENTRALNIC_ENV=ote
