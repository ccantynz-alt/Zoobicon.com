# Zoobicon Environment Variables
# ⚠️ NEVER commit the .env.local file — only this template
# Copy this file to .env.local and fill in real values

# ════════════════════════════════════════════════════════════
#  CORE AI — TEXT & CODE GENERATION
# ════════════════════════════════════════════════════════════

# Anthropic Claude (primary AI engine)
# https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI — GPT-4o, o3, DALL-E 3
# https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini 2.0 — large context, fast, great for code
# https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=your_google_gemini_api_key_here

# xAI Grok 3 — web-aware, strong coder
# https://console.x.ai/
XAI_API_KEY=your_xai_api_key_here

# Groq — ultra-fast inference (Llama 3.3, Mixtral, Gemma)
# https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Mistral AI — European frontier models, code-optimized
# https://console.mistral.ai/api-keys/
MISTRAL_API_KEY=your_mistral_api_key_here

# Cohere — RAG, embeddings, reranking
# https://dashboard.cohere.com/api-keys
COHERE_API_KEY=your_cohere_api_key_here

# Perplexity — real-time web-aware AI search
# https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# ════════════════════════════════════════════════════════════
#  IMAGE GENERATION
# ════════════════════════════════════════════════════════════

# Stability AI — Stable Diffusion 3.5, SDXL
# https://platform.stability.ai/account/keys
STABILITY_API_KEY=your_stability_api_key_here

# Replicate — Flux, SDXL, and 1000s of open-source models
# https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=your_replicate_api_token_here

# Fal.ai — fastest Flux inference, real-time image gen
# https://fal.ai/dashboard/keys
FAL_API_KEY=your_fal_api_key_here

# Ideogram — best-in-class text-in-image generation
# https://ideogram.ai/manage-api
IDEOGRAM_API_KEY=your_ideogram_api_key_here

# ════════════════════════════════════════════════════════════
#  VIDEO GENERATION
# ════════════════════════════════════════════════════════════

# Runway ML — Gen-3 Alpha, cinematic AI video
# https://app.runwayml.com/settings
RUNWAY_API_KEY=your_runway_api_key_here

# Luma AI — Dream Machine, photorealistic video
# https://lumalabs.ai/dream-machine/api
LUMA_API_KEY=your_luma_api_key_here

# Pika Labs — fast video generation & lip sync
# https://pika.art/
PIKA_API_KEY=your_pika_api_key_here

# Kling AI — high-fidelity video, motion control
# https://klingai.com/
KLING_API_KEY=your_kling_api_key_here

# ════════════════════════════════════════════════════════════
#  VOICE & AUDIO
# ════════════════════════════════════════════════════════════

# ElevenLabs — best-in-class AI voice cloning & TTS
# https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Play.ht — ultra-realistic TTS, 900+ voices
# https://play.ht/studio/api-access
PLAYHT_API_KEY=your_playht_api_key_here
PLAYHT_USER_ID=your_playht_user_id_here

# ════════════════════════════════════════════════════════════
#  SEO & SEARCH INTELLIGENCE
# ════════════════════════════════════════════════════════════

# DataForSEO — keyword research, SERP, backlinks, audits
# https://app.dataforseo.com/api-access
DATAFORSEO_LOGIN=your_dataforseo_login_here
DATAFORSEO_PASSWORD=your_dataforseo_password_here

# Serper — Google Search API (cheapest, fastest)
# https://serper.dev/api-key
SERPER_API_KEY=your_serper_api_key_here

# Tavily — AI-optimized search for RAG pipelines
# https://app.tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# Brave Search — privacy-first independent search index
# https://api.search.brave.com/
BRAVE_SEARCH_API_KEY=your_brave_search_api_key_here

# Google Search Console (OAuth — for site analytics)
GOOGLE_SEARCH_CONSOLE_CLIENT_ID=your_gsc_client_id_here
GOOGLE_SEARCH_CONSOLE_CLIENT_SECRET=your_gsc_client_secret_here

# ════════════════════════════════════════════════════════════
#  MEDIA & ASSETS
# ════════════════════════════════════════════════════════════

# Cloudinary — image/video hosting, transforms, CDN
# https://console.cloudinary.com/
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name_here
CLOUDINARY_API_KEY=your_cloudinary_api_key_here
CLOUDINARY_API_SECRET=your_cloudinary_api_secret_here

# Unsplash — free stock photos API
# https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# Pexels — free stock photos & videos
# https://www.pexels.com/api/
PEXELS_API_KEY=your_pexels_api_key_here

# ════════════════════════════════════════════════════════════
#  ANALYTICS & MONITORING
# ════════════════════════════════════════════════════════════

# PostHog — product analytics, session recordings, feature flags
# https://app.posthog.com/project/settings
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_key_here
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ════════════════════════════════════════════════════════════
#  ADMIN & AUTH
# ════════════════════════════════════════════════════════════

# Admin login credentials
ADMIN_EMAIL=admin@zoobicon.com
ADMIN_PASSWORD=change-me-to-something-strong

# Email — password reset (Resend)
# https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_key_here

# Public base URL
NEXT_PUBLIC_APP_URL=https://zoobicon.com

# ════════════════════════════════════════════════════════════
#  STRIPE — PAYMENTS
# ════════════════════════════════════════════════════════════

# Secret key — server-side only (never expose to client)
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# Publishable key — safe to expose to client
# https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# Price ID for the Pro plan ($49/month recurring)
# Create at: https://dashboard.stripe.com/products → Add product
STRIPE_PRO_PRICE_ID=price_your_pro_price_id_here

# Webhook signing secret — validates incoming Stripe events
# Local dev: stripe listen --forward-to localhost:3000/api/stripe/webhook
# Production: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
