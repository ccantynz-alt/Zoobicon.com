{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "regions": [
    "iad1"
  ],
  "functions": {
    "src/app/api/health/route.ts": {
      "maxDuration": 120,
      "memory": 1024
    },
    "src/app/api/generate/route.ts": {
      "maxDuration": 300,
      "memory": 1024
    },
    "src/app/api/generate/stream/route.ts": {
      "maxDuration": 300,
      "memory": 2048
    },
    "src/app/api/generate/pipeline/route.ts": {
      "maxDuration": 300,
      "memory": 1024
    },
    "src/app/api/generate/pipeline-stream/route.ts": {
      "maxDuration": 300,
      "memory": 1024
    },
    "src/app/api/generate/quick/route.ts": {
      "maxDuration": 300,
      "memory": 1024
    },
    "src/app/api/intel/cron/route.ts": {
      "maxDuration": 300,
      "memory": 1024
    },
    "src/app/api/auto-pilot/cron/route.ts": {
      "maxDuration": 300,
      "memory": 1024
    },
    "src/app/api/chat/route.ts": {
      "maxDuration": 300,
      "memory": 1024
    },
    "src/app/api/support/route.ts": {
      "maxDuration": 60,
      "memory": 512
    },
    "src/app/api/seo/agent/cron/route.ts": {
      "maxDuration": 300,
      "memory": 1024
    },
    "src/app/api/video-creator/render/route.ts": {
      "maxDuration": 120,
      "memory": 1024
    },
    "src/app/api/generate/launch-video/route.ts": {
      "maxDuration": 300,
      "memory": 1024
    },
    "src/app/api/video-creator/dub/route.ts": {
      "maxDuration": 300,
      "memory": 1024
    },
    "src/app/api/cron/flywheel-consolidate/route.ts": {
      "maxDuration": 300,
      "memory": 1024
    },
    "src/app/api/cron/prebuild-factory/route.ts": {
      "maxDuration": 300,
      "memory": 1024
    },
    "src/app/api/cron/self-heal/route.ts": {
      "maxDuration": 120,
      "memory": 512
    },
    "src/app/api/generate/slot-stream/route.ts": {
      "maxDuration": 300,
      "memory": 1024
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-DNS-Prefetch-Control",
          "value": "on"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    },
    {
      "source": "/_next/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/fonts/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, stale-while-revalidate=604800"
        }
      ]
    }
  ]
}
